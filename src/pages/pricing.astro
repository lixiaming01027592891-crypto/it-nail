---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="價格表 | 台北中山區美甲價格透明公開" description="伊特美甲台北中山區透明價格表：凝膠美甲 NT$1,200 起、光療延甲 NT$1,500 起、手足保養 NT$800 起。新客首次預約享 9 折優惠。">
  <Header />
  <main class="pt-8 pb-20">
    <div class="max-w-4xl mx-auto px-4">
      <nav class="text-sm text-it-text mb-4"><a href="/" class="hover:text-it-cta">首頁</a> <span class="mx-2">/</span> <span>價格表</span></nav>
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-serif font-bold text-it-dark mb-4">價格表</h1>
        <p class="text-it-text">透明報價，現場確認後才開始操作。新客首次預約享 9 折優惠。</p>
      </div>
      <div class="space-y-8">
        <div class="bg-white rounded-2xl p-8 border border-it-secondary/20">
          <h2 class="text-xl font-bold text-it-dark mb-4">凝膠美甲</h2>
          <table class="w-full text-sm">
            <tr class="border-b border-it-secondary/20"><td class="py-3">單色凝膠</td><td class="py-3 text-right font-bold text-it-cta">NT$1,200</td></tr>
            <tr class="border-b border-it-secondary/20"><td class="py-3">貓眼 / 漸層</td><td class="py-3 text-right font-bold text-it-cta">NT$1,500</td></tr>
            <tr class="border-b border-it-secondary/20"><td class="py-3">簡單設計款</td><td class="py-3 text-right font-bold text-it-cta">NT$1,800 起</td></tr>
            <tr><td class="py-3">複雜設計款</td><td class="py-3 text-right font-bold text-it-cta">NT$2,500 起</td></tr>
          </table>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-it-secondary/20">
          <h2 class="text-xl font-bold text-it-dark mb-4">光療延甲</h2>
          <table class="w-full text-sm">
            <tr class="border-b border-it-secondary/20"><td class="py-3">單指延甲</td><td class="py-3 text-right font-bold text-it-cta">NT$150</td></tr>
            <tr><td class="py-3">全手延甲</td><td class="py-3 text-right font-bold text-it-cta">NT$1,500 起</td></tr>
          </table>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-it-secondary/20">
          <h2 class="text-xl font-bold text-it-dark mb-4">手足保養</h2>
          <table class="w-full text-sm">
            <tr class="border-b border-it-secondary/20"><td class="py-3">手部基礎保養</td><td class="py-3 text-right font-bold text-it-cta">NT$800</td></tr>
            <tr class="border-b border-it-secondary/20"><td class="py-3">足部基礎保養</td><td class="py-3 text-right font-bold text-it-cta">NT$1,000</td></tr>
            <tr><td class="py-3">深層護理療程</td><td class="py-3 text-right font-bold text-it-cta">NT$1,500</td></tr>
          </table>
        </div>
        <div class="bg-it-cta text-white rounded-2xl p-8 text-center">
          <h2 class="text-2xl font-bold mb-4">新客首次預約享 9 折</h2>
          <p class="mb-6">透過 LINE 預約並告知「新客優惠」即可享有折扣</p>
          <a href="https://line.me/R/ti/p/@itnail" target="_blank" rel="noopener" class="inline-block px-8 py-3 bg-white text-it-cta font-bold rounded-full hover:bg-it-light transition-colors">LINE 立即預約</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
