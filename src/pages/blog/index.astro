---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
const posts = [
  { title: '新店造型美甲款式怎麼挑？美甲師的熱門風格解析與選款指南', excerpt: '新店造型美甲款式怎麼挑？美甲師解析貓眼、法式、漸層、暈染四大熱門風格各適合哪種人，並分享依場合、生活型態與指型選款的實務建議。', date: '2026-07-16', href: '/blog/styling-nail-trends-20260716' },
  { title: '新娘婚禮美甲怎麼準備？景美美甲師的婚前時程規劃與款式提案', excerpt: '新娘婚禮美甲該提前多久做？景美美甲師分享婚前手部保養時程、試做的重要性、婚紗與捧花配色原則，以及讓美甲撐過婚宴與蜜月的實務建議。', date: '2026-07-14', href: '/blog/bridal-wedding-nails-20260714' },
  { title: '新店美甲教學｜凝膠美甲課程與手足護理完整指南', excerpt: '新店美甲教學從基礎到進階。凝膠美甲課程小班制，手足護理從 $600 起。新店區公所捷運站步行 5 分鐘，十二年經驗師資。', date: '2025-07-10', href: '/blog/post-11' },
  { title: '景美手部保養推薦｜景美美甲店的專業護理與凝膠美甲', excerpt: '景美手部保養推薦。基礎保養 $600、深層保養 $1,000，凝膠美甲 $999 起。景美美甲店十二年經驗，景美捷運站步行 5 分鐘。', date: '2025-07-10', href: '/blog/post-10' },
  { title: '新店凝膠美甲與手足護理｜美甲課程從基礎到進階', excerpt: '新店凝膠美甲 $999 起，手足護理從 $600 起。美甲課程從基礎到進階，小班制教學。新店區公所捷運站步行 5 分鐘。', date: '2025-07-08', href: '/blog/post-9' },
  { title: '景美足部保養推薦｜景美美甲店的深層護理體驗', excerpt: '景美足部保養推薦。基礎保養 $800、深層保養 $1,500 起、潤澤課程 $1,500。景美美甲店十二年經驗。', date: '2025-07-08', href: '/blog/post-8' },
  { title: '新店凝膠美甲｜造型設計與美甲課程完整指南', excerpt: '新店凝膠美甲 $999 起，造型設計另外報價。美甲課程從基礎到進階。新店區公所捷運站 1 號出口步行 5 分鐘。', date: '2025-07-06', href: '/blog/post-7' },
  { title: '景美美甲店推薦｜手部保養與凝膠美甲的專業選擇', excerpt: '景美美甲店推薦。手部基礎保養 $600、深層保養 $1,000，凝膠美甲 $999 起。景美捷運站步行 5 分鐘。', date: '2025-07-06', href: '/blog/post-6' },
  { title: '足部深層保養攻略｜台北美甲沙龍的專業護理體驗', excerpt: '完整足部保養指南。基礎保養 $600 起、深層保養 $1,000 起、TRInd 精油強效淨化 $2,500。三種方案比較與選擇建議。', date: '2025-06-20', href: '/blog/post-5' },
  { title: '景美美甲推薦｜凝膠美甲價格、款式與預約完整指南', excerpt: '景美地區美甲推薦完整指南。凝膠美甲 $999 起，貓眼/法式/漸層 $1,500，魔鏡粉 $1,800。十二年經驗美甲師分享選店技巧。', date: '2025-06-15', href: '/blog/post-4' },
  { title: '凝膠美甲可以維持多久？保養秘訣公開', excerpt: '凝膠美甲一般可維持 2-3 週，正確保養可延長至 4 週。了解影響持久度的因素與保養技巧。', date: '2025-01-15', href: '/blog/post-1' },
  { title: '景美・新店美甲推薦：如何選擇適合自己的美甲店？', excerpt: '選擇美甲店的五大要點：衛生標準、技術認證、作品風格、價格透明與顧客評價。', date: '2025-01-10', href: '/blog/post-2' },
  { title: '穿戴甲 vs 凝膠美甲：哪個適合你？', excerpt: '比較穿戴甲與凝膠美甲的優缺點、適合場合、價格與維護方式。', date: '2025-01-05', href: '/blog/post-3' },
];
---
<Layout title="部落格 | 美甲知識・保養技巧・最新趨勢" description="伊特美甲部落格，分享景美新店美甲知識、凝膠保養技巧、穿戴甲教學與最新美甲趨勢。">
  <Header />
  <main class="pt-8 pb-20">
    <div class="max-w-4xl mx-auto px-4">
      <nav class="text-sm text-it-text mb-4"><a href="/" class="hover:text-it-cta">首頁</a> <span class="mx-2">/</span> <span>部落格</span></nav>
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-serif font-bold text-it-dark mb-4">美甲知識部落格</h1>
        <p class="text-it-text">凝膠保養技巧、穿戴甲教學與最新美甲趨勢</p>
      </div>
      <div class="space-y-6">
        {posts.map(post => (
          <a href={post.href} class="block bg-white rounded-xl p-6 border border-it-secondary/20 hover:shadow-md transition-shadow">
            <p class="text-xs text-it-cta mb-2">{post.date}</p>
            <h2 class="text-xl font-bold text-it-dark mb-2">{post.title}</h2>
            <p class="text-it-text text-sm">{post.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
