---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "NailSalon",
  "name": "ITUNG NAILS 伊特美甲",
  "image": "https://itnail-kimi.pages.dev/images/og-default.jpg",
  "url": "https://itnail-kimi.pages.dev",
  "sameAs": [
    "https://www.instagram.com/itung_lin_nails/",
    "https://www.facebook.com/itung.lin.nails/"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "台北市文山區景美",
    "addressRegion": "台北",
    "addressCountry": "TW"
  },
  "areaServed": [
    { "@type": "City", "name": "台北市景美" },
    { "@type": "City", "name": "新北市新店" }
  ],
  "priceRange": "$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "500"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "伊特美甲在哪裡？",
      "acceptedAnswer": { "@type": "Answer", "text": "ITUNG NAILS 伊特美甲位於台北市文山區景美及新北市新店區附近，詳細地址請透過 Instagram 私訊詢問。" }
    },
    {
      "@type": "Question",
      "name": "如何預約伊特美甲？",
      "acceptedAnswer": { "@type": "Answer", "text": "目前主要透過 Instagram 私訊 @itung_lin_nails 進行預約。" }
    },
    {
      "@type": "Question",
      "name": "伊特美甲的價格大約多少？",
      "acceptedAnswer": { "@type": "Answer", "text": "伊特美甲主打平價高CP值，凝膠美甲價格親民，詳細價目表請參考網站價格頁或 IG 私訊詢問。" }
    }
  ]
};

const services = [
  { title: '凝膠美甲', desc: '專業凝膠上色，色彩飽和持久，平價高CP值首選。', href: '/services' },
  { title: '手足保養', desc: '深層滋養與角質護理，讓雙手雙足恢復細緻柔嫩。', href: '/services#care' },
  { title: '光療延甲', desc: '改善甲型問題，打造完美長度與弧度。', href: '/services#extension' },
  { title: 'Nail Art 設計', desc: '從簡約到華麗，依據您的風格量身設計。', href: '/gallery' },
];
---
<Layout title="ITUNG NAILS 伊特美甲 | 景美・新店平價高CP值美甲" description="ITUNG NAILS 伊特美甲，台北景美、新店地區平價高CP值美甲沙龍。IG 10K+ 粉絲推薦，專業凝膠美甲與手足保養。" schema={[localBusinessSchema, faqSchema]}>
  <Header />
  <main>
    <section class="relative min-h-[90vh] flex items-center bg-it-primary overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-it-secondary/20 via-transparent to-it-blush/10"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-it-cta text-sm tracking-[0.3em] uppercase mb-4 font-medium">ITUNG NAILS · 景美・新店</p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-it-dark mb-6 leading-tight">
            台北景美・新店<br/>
            <span class="text-it-cta">平價高CP值</span><br/>
            美甲沙龍
          </h1>
          <p class="text-lg text-it-text mb-8 max-w-lg leading-relaxed">
            ITUNG NAILS 伊特美甲，IG 10K+ 粉絲推薦的專業美甲工作室。提供凝膠美甲、手足保養、光療延甲與 nail art 設計，以親民價格享受高品質服務。
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="https://www.instagram.com/itung_lin_nails/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-it-cta text-white font-bold rounded-full hover:bg-it-cta/90 transition-colors shadow-lg">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              <span>IG 私訊預約</span>
            </a>
            <a href="/pricing" class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-it-dark text-it-dark font-bold rounded-full hover:bg-it-dark hover:text-white transition-colors">
              <span>查看價格表</span>
            </a>
          </div>
          <div class="mt-8 flex items-center gap-6 text-sm text-it-text">
            <div class="flex items-center gap-1">
              <span class="text-yellow-500">★★★★★</span>
              <span class="font-bold">4.8</span>
              <span>(多家部落格推薦)</span>
            </div>
            <div class="flex items-center gap-1">
              <svg class="w-4 h-4 text-it-cta" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span>景美・新店地區</span>
            </div>
          </div>
        </div>
        <div class="hidden lg:block relative">
          <div class="aspect-[4/5] rounded-3xl bg-gradient-to-br from-it-secondary/40 to-it-blush/30 flex items-center justify-center">
            <img src="/images/og-default.jpg" alt="ITUNG NAILS 伊特美甲" class="w-full h-full object-cover rounded-3xl" loading="eager" />
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white border-b border-it-secondary/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-8 text-center">
          <div class="p-6 rounded-2xl bg-it-primary/50">
            <h3 class="font-bold text-it-dark mb-2">📍 景美・新店美甲</h3>
            <p class="text-sm text-it-text">台北市文山區景美及新北市新店區，交通便利的社區美甲工作室。</p>
          </div>
          <div class="p-6 rounded-2xl bg-it-primary/50">
            <h3 class="font-bold text-it-dark mb-2">📸 IG 10K+ 推薦</h3>
            <p class="text-sm text-it-text">Instagram @itung_lin_nails 累積 10K+ 粉絲、972 篇作品分享。</p>
          </div>
          <div class="p-6 rounded-2xl bg-it-primary/50">
            <h3 class="font-bold text-it-dark mb-2">💰 平價高CP值</h3>
            <p class="text-sm text-it-text">多家部落格評比推薦的平價高品質美甲沙龍，小資族首選。</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-28 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <p class="text-it-cta text-sm tracking-widest uppercase mb-3 font-medium">Our Services</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-it-dark">伊特美甲服務項目</h2>
          <p class="mt-4 text-it-text max-w-2xl mx-auto">專業美甲服務，以親民價格享受沙龍級品質。</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {services.map(service => (
            <a href={service.href} class="group block bg-it-light rounded-2xl p-6 hover:shadow-lg transition-all border border-transparent hover:border-it-secondary/30">
              <div class="w-12 h-12 rounded-xl bg-it-secondary/30 flex items-center justify-center mb-4 group-hover:bg-it-cta/10 transition-colors">
                <svg class="w-6 h-6 text-it-cta" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
              </div>
              <h3 class="text-lg font-bold text-it-dark mb-2">{service.title}</h3>
              <p class="text-sm text-it-text leading-relaxed">{service.desc}</p>
              <div class="mt-4 flex items-center text-it-cta text-sm font-medium">
                <span>了解詳情</span>
            
