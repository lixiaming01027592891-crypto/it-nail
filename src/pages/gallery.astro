---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const works = [
  { title: '極簡裸色', tag: '凝膠', alt: '極簡裸色凝膠美甲作品' },
  { title: '花卉手繪', tag: '手繪', alt: '花卉手繪凝膠美甲作品' },
  { title: '鏡面貓眼', tag: '貓眼', alt: '鏡面貓眼凝膠美甲作品' },
  { title: '法式經典', tag: '法式', alt: '法式經典凝膠美甲作品' },
  { title: '漸層暈染', tag: '漸層', alt: '漸層暈染凝膠美甲作品' },
  { title: '幾何線條', tag: '設計', alt: '幾何線條凝膠美甲作品' },
];
---
<Layout title="作品集 | 伊特美甲精選美甲作品" description="伊特美甲作品集，包含台北中山區凝膠美甲、手繪花卉、貓眼、法式、漸層等多種風格。立即預約同款設計。">
  <Header />
  <main class="pt-8 pb-20">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-it-text mb-4"><a href="/" class="hover:text-it-cta">首頁</a> <span class="mx-2">/</span> <span>作品集</span></nav>
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-serif font-bold text-it-dark mb-4">作品集</h1>
        <p class="text-it-text">精選美甲作品，每個設計都是獨一無二的藝術創作。歡迎帶圖預約同款。</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {works.map(work => (
          <div class="aspect-square rounded-xl bg-it-secondary/30 flex flex-col items-center justify-center hover:shadow-md transition-shadow">
            <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center mb-3">
              <span class="text-2xl" role="img" aria-label={work.alt}>💅</span>
            </div>
            <p class="font-medium text-it-dark">{work.title}</p>
            <span class="text-xs text-it-text mt-1 px-2 py-0.5 bg-white rounded-full">{work.tag}</span>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="https://line.me/R/ti/p/@itnail" target="_blank" class="inline-flex items-center gap-2 px-8 py-4 bg-it-cta text-white font-bold rounded-full hover:bg-it-cta/90 transition-colors">帶圖詢問預約</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
