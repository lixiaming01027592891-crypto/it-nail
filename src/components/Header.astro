---
const navItems = [
  { label: '首頁', href: '/' },
  { label: '凝膠美甲服務', href: '/services/gel-nails' },
  { label: '穿戴甲訂製', href: '/services/press-on-nails' },
  { label: '手足保養', href: '/services/manicure-pedicure' },
  { label: '美甲教學課程', href: '/courses' },
  { label: '價格表', href: '/pricing' },
  { label: '常見問題 FAQ', href: '/faq' },
  { label: '作品集', href: '/gallery' },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex flex-col">
        <span class="text-xl lg:text-2xl font-serif font-bold text-it-dark tracking-wide">伊特美甲</span>
        <span class="text-[10px] text-it-accent tracking-[0.2em] uppercase">It Nail Studio · 台北中山區</span>
      </a>
      
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map(item => (
          <a 
            href={item.href}
            class="px-2 xl:px-3 py-2 text-sm text-it-text hover:text-it-cta transition-colors rounded-md hover:bg-it-secondary/30"
          >
            {item.label}
          </a>
        ))}
      </nav>
      
      <div class="flex items-center gap-3">
        <a 
          href="tel:+886-2-0000-0000"
          class="hidden md:flex items-center gap-1 text-sm text-it-text hover:text-it-cta transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <span>02-0000-0000</span>
        </a>
        <a 
          href="https://line.me/R/ti/p/@itnail" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-it-cta text-white text-sm font-bold rounded-full hover:bg-it-cta/90 transition-colors shadow-md"
        >
          <span>立即預約</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </div>
</header>
