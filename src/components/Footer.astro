---
const serviceLinks = [
  { label: '凝膠美甲', href: '/services/gel-nails' },
  { label: '光療延甲', href: '/services/gel-extension' },
  { label: '手足保養', href: '/services/manicure-pedicure' },
  { label: '穿戴甲訂製', href: '/services/press-on-nails' },
];

const infoLinks = [
  { label: '價格表', href: '/pricing' },
  { label: '常見問題 FAQ', href: '/faq' },
  { label: '作品集', href: '/gallery' },
  { label: '部落格', href: '/blog' },
];

const locationLinks = [
  { label: '台北中山店', href: '/locations/zhongshan' },
  { label: '台北信義店', href: '/locations/xinyi' },
];
---

<footer class="bg-it-dark text-white/80" itemscope itemtype="https://schema.org/LocalBusiness">
  <meta itemprop="name" content="伊特美甲 It Nail" />
  <meta itemprop="image" content="https://itnail-kimi.pages.dev/images/og-default.jpg" />
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <h3 class="text-lg font-serif font-bold text-white mb-4">伊特美甲 It Nail</h3>
        <p class="text-sm leading-relaxed mb-4" itemprop="description">
          台北中山區精緻凝膠美甲工作室，提供光療美甲、手足保養、穿戴甲訂製與日式美甲教學課程。
        </p>
        <div class="flex gap-3">
          <a href="https://instagram.com/itnail" target="_blank" rel="noopener" class="px-3 py-1 bg-white/10 rounded-full text-xs hover:bg-it-cta transition-colors">Instagram</a>
          <a href="https://line.me/R/ti/p/@itnail" target="_blank" rel="noopener" class="px-3 py-1 bg-white/10 rounded-full text-xs hover:bg-it-cta transition-colors">LINE</a>
        </div>
      </div>
      
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-4">服務項目</h4>
        <ul class="space-y-2">
          {serviceLinks.map(link => (
            <li><a href={link.href} class="text-sm hover:text-it-blush transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-4">資訊中心</h4>
        <ul class="space-y-2">
          {infoLinks.map(link => (
            <li><a href={link.href} class="text-sm hover:text-it-blush transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-wider mb-4">分店資訊</h4>
        <ul class="space-y-2">
          {locationLinks.map(link => (
            <li><a href={link.href} class="text-sm hover:text-it-blush transition-colors">{link.label}</a></li>
          ))}
        </ul>
        <div class="mt-4 text-sm space-y-1">
          <p itemprop="telephone">📞 02-0000-0000</p>
          <p itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
            <span itemprop="addressLocality">台北市中山區</span>
          </p>
        </div>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-white/60">© 2025 伊特美甲 It Nail. All rights reserved.</p>
      <div class="flex gap-4 text-xs text-white/60">
        <a href="/privacy" class="hover:text-white transition-colors">隱私政策</a>
        <a href="/terms" class="hover:text-white transition-colors">服務條款</a>
      </div>
    </div>
  </div>
</footer>
